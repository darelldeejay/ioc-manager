# Configuración de Seguridad
# Generar una clave segura con: python -c 'import secrets; print(secrets.token_hex(32))'
FLASK_SECRET_KEY=cambiar_esto_por_una_clave_segura

# Credenciales de Administrador
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# Nombre del segundo feed (visible en la UI y en los tags)
# Cambiar por el nombre real del cliente en cada entorno (preprod/prod)
# El archivo de feed en disco siempre se llama ioc-feed-bpe.txt
FEED2_TAG=Cliente

# Configuración de la API (Opcional)
# TOKEN_API=token_seguro_para_api
# API_ALLOWLIST=1.2.3.0/24,10.0.0.0/8
# RATE_LIMIT_PER_MIN=60

# Licenciamiento / Billing (PayPal)
# ENFORCE_LICENSE=1
# LICENSE_GRACE_DAYS=7
# PAYPAL_MODE=live
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
